generator client {
  provider = "prisma-client-py"
  recursive_type_depth = 5
  interface = "asyncio"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Case {
  id          String   @id @default(cuid())
  title       String
  description String?
  status      String   @default("PENDING")
  caseNumber  String   @unique
  createdAt   DateTime @default(now())
}
